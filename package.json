{
	"name": "steam-achievement-hunter",
	"version": "0.3.0",
	"type": "module",
	"scripts": {
		"build": "rollup -c",
		"watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.maxik.steam-achievements\"",
		"test": "vitest run",
		"test:watch": "vitest",
		"simulate": "tsx src/simulator/simulate.ts",
		"package": "npm run gen-icons && npm run gen-profiles && npm run build && streamdeck pack com.maxik.steam-achievements.sdPlugin --force",
		"gen-profiles": "node scripts/gen-profiles.mjs",
		"gen-icons": "tsx scripts/generate-icons.ts",
		"bump": "node scripts/bump-version.mjs"
	},
	"dependencies": {
		"@elgato/streamdeck": "^2.0.1"
	},
	"devDependencies": {
		"@elgato/cli": "^1.7.0",
		"@rollup/plugin-commonjs": "^28.0.2",
		"@rollup/plugin-json": "^6.1.0",
		"@rollup/plugin-node-resolve": "^16.0.0",
		"@rollup/plugin-terser": "^1.0.0",
		"@rollup/plugin-typescript": "^12.1.2",
		"@tsconfig/node20": "^20.1.4",
		"@types/node": "^22.13.0",
		"rollup": "^4.32.1",
		"tslib": "^2.8.1",
		"tsx": "^4.21.0",
		"typescript": "^5.7.3",
		"vitest": "^4.0.18"
	}
}
