{
	"extends": "@tsconfig/node20/tsconfig.json",
	"compilerOptions": {
		"customConditions": ["node"],
		"noImplicitOverride": true,
		"module": "ES2022",
		"moduleResolution": "Bundler",
		"resolveJsonModule": true,
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "src/__tests__", "src/simulator"]
}
