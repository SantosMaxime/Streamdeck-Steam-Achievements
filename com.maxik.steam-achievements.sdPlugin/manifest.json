{
	"Name": "Steam Achievement Hunter",
	"Version": "0.3.0.0",
	"Author": "Maxik",
	"Description": "Track Steam achievements in real-time on your Stream Deck. Auto-detect running games, monitor unlock progress, and view global stats.",
	"Category": "Steam Achievement Hunter",
	"CategoryIcon": "imgs/plugin/category-icon",
	"CodePath": "bin/plugin.js",
	"Icon": "imgs/plugin/marketplace",
	"SDKVersion": 2,
	"Software": {
		"MinimumVersion": "6.6"
	},
	"OS": [
		{
			"Platform": "windows",
			"MinimumVersion": "10"
		}
	],
	"Nodejs": {
		"Version": "20",
		"Debug": "enabled"
	},
	"UUID": "com.maxik.steam-achievements",
	"Profiles": [
		{
			"Name": "profiles/grid-standard",
			"DeviceType": 0,
			"AutoInstall": true,
			"DontAutoSwitchWhenInstalled": false,
			"Readonly": false
		},
		{
			"Name": "profiles/grid-mini",
			"DeviceType": 1,
			"AutoInstall": true,
			"DontAutoSwitchWhenInstalled": false,
			"Readonly": false
		},
		{
			"Name": "profiles/grid-xl",
			"DeviceType": 2,
			"AutoInstall": true,
			"DontAutoSwitchWhenInstalled": false,
			"Readonly": false
		},
		{
			"Name": "profiles/grid-plus",
			"DeviceType": 7,
			"AutoInstall": true,
			"DontAutoSwitchWhenInstalled": false,
			"Readonly": false
		},
		{
			"Name": "profiles/grid-plus",
			"DeviceType": 9,
			"AutoInstall": true,
			"DontAutoSwitchWhenInstalled": false,
			"Readonly": false
		}
	],
	"Actions": [
		{
			"Name": "Dashboard: Steam Level",
			"UUID": "com.maxik.steam-achievements.dashboard-level",
			"Icon": "imgs/actions/dashboard/icon",
			"Tooltip": "Displays your current Steam level.",
			"PropertyInspectorPath": "ui/dashboard.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/dashboard/key",
					"TitleAlignment": "bottom",
					"FontSize": 12
				}
			]
		},
		{
			"Name": "Dashboard: Total Achievements",
			"UUID": "com.maxik.steam-achievements.dashboard-total",
			"Icon": "imgs/actions/dashboard/icon",
			"Tooltip": "Displays your total number of unlocked achievements across all games.",
			"PropertyInspectorPath": "ui/dashboard.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/dashboard/key",
					"TitleAlignment": "bottom",
					"FontSize": 12
				}
			]
		},
		{
			"Name": "Dashboard: Perfect Games",
			"UUID": "com.maxik.steam-achievements.dashboard-perfect",
			"Icon": "imgs/actions/dashboard/icon",
			"Tooltip": "Displays the number of games where you unlocked 100% of achievements.",
			"PropertyInspectorPath": "ui/dashboard.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/dashboard/key",
					"TitleAlignment": "bottom",
					"FontSize": 12
				}
			]
		},
		{
			"Name": "Achievement Radar",
			"UUID": "com.maxik.steam-achievements.achievement-radar",
			"Icon": "imgs/actions/radar/icon",
			"Tooltip": "Detects the currently running Steam game and displays the next locked achievement with its icon and progress.",
			"PropertyInspectorPath": "ui/radar.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/radar/key",
					"TitleAlignment": "bottom",
					"FontSize": 9
				}
			]
		},
		{
			"Name": "Grid: Cell",
			"UUID": "com.maxik.steam-achievements.grid-cell",
			"Icon": "imgs/actions/grid-cell/icon",
			"Tooltip": "Displays a single achievement from the grid. Place multiple cells to create a gallery view.",
			"PropertyInspectorPath": "ui/grid-cell.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/grid-cell/key",
					"TitleAlignment": "bottom",
					"FontSize": 8
				}
			]
		},
		{
			"Name": "Grid: Previous Page",
			"UUID": "com.maxik.steam-achievements.grid-prev",
			"Icon": "imgs/actions/grid-nav/icon",
			"Tooltip": "Navigate to the previous page of achievements.",
			"PropertyInspectorPath": "ui/grid-prev.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/grid-nav/key",
					"TitleAlignment": "bottom",
					"FontSize": 10
				}
			]
		},
		{
			"Name": "Grid: Next Page",
			"UUID": "com.maxik.steam-achievements.grid-next",
			"Icon": "imgs/actions/grid-nav/icon",
			"Tooltip": "Navigate to the next page of achievements.",
			"PropertyInspectorPath": "ui/grid-next.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/grid-nav/key",
					"TitleAlignment": "bottom",
					"FontSize": 10
				}
			]
		},
		{
			"Name": "Grid: Info & Config",
			"UUID": "com.maxik.steam-achievements.grid-info",
			"Icon": "imgs/actions/grid-info/icon",
			"Tooltip": "Shows game progress ring. Press to switch display or cycle sort. Configure grid-wide settings here.",
			"PropertyInspectorPath": "ui/grid-info.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/grid-info/key",
					"TitleAlignment": "bottom",
					"FontSize": 8
				}
			]
		},
		{
			"Name": "Load Game",
			"UUID": "com.maxik.steam-achievements.game-browser",
			"Icon": "imgs/actions/game-browser/icon",
			"Tooltip": "Select a game from your library to load into the achievement grid.",
			"PropertyInspectorPath": "ui/game-browser.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/game-browser/key",
					"TitleAlignment": "bottom",
					"FontSize": 9
				}
			]
		},
		{
			"Name": "Daily Pick",
			"UUID": "com.maxik.steam-achievements.daily-pick",
			"Icon": "imgs/actions/daily-pick/icon",
			"Tooltip": "Suggests a random locked achievement each day. Press to open a guide.",
			"PropertyInspectorPath": "ui/daily-pick.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/daily-pick/key",
					"TitleAlignment": "bottom",
					"FontSize": 9
				}
			]
		},
		{
			"Name": "Settings",
			"UUID": "com.maxik.steam-achievements.settings",
			"Icon": "imgs/actions/settings/icon",
			"Tooltip": "Configure your Steam API key and Steam ID once. Press to test the connection.",
			"PropertyInspectorPath": "ui/settings.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/settings/key",
					"TitleAlignment": "bottom",
					"FontSize": 10
				}
			]
		},
		{
			"Name": "Profile Launcher",
			"UUID": "com.maxik.steam-achievements.profile-launcher",
			"Icon": "imgs/actions/profile-launcher/icon",
			"Tooltip": "Jump to the achievement grid profile. Auto-detects your device type or use a custom profile name.",
			"PropertyInspectorPath": "ui/profile-launcher.html",
			"Controllers": [
				"Keypad"
			],
			"States": [
				{
					"Image": "imgs/actions/profile-launcher/key",
					"TitleAlignment": "bottom",
					"FontSize": 10
				}
			]
		}
	]
}
